# ---------------------------------------------------------------------------
# Minna — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# --- Database: Neon (Postgres) --------------------------------------------
# Neon connection string (pooled). Used by Drizzle (src/db) and drizzle-kit.
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/minna?sslmode=require"

# --- Cache: Redis ----------------------------------------------------------
# Redis connection URL. If unset, the cache layer becomes a no-op (dev only).
REDIS_URL="redis://default:password@host:6379"

# --- Data source: embedded Consumet (@consumet/extensions) -----------------
# Anime data is fetched in-process via the embedded AniList provider — no
# external Consumet server is required. Metadata comes from AniList's GraphQL
# API; episode lists and playable streams come from a scraping sub-provider.
# These sources are volatile: if the default is down, switch here with no code
# change. One of: animeunity (default), animekai, animepahe, hianime,
# kickassanime, animesama, animesaturn. As of mid-2026 only animeunity resolves
# episodes AND playable sources end-to-end (the English providers' domains died
# or their markup moved in this library version). Note: animeunity is an Italian
# catalogue, so audio/subtitles may be Italian. Metadata is always from AniList.
ANIME_PROVIDER="animeunity"

# --- Authentication: Google OAuth (only auth method) -----------------------
# From Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Auth.js / NextAuth session config (AUTH-01/04).
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-32-byte-random-secret"
# Canonical URL of the app (http://localhost:3000 in dev).
NEXTAUTH_URL="http://localhost:3000"

# --- Misc ------------------------------------------------------------------
# Public site URL used for metadata / sitemap / Open Graph (PERF-01).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Optional: endpoint that receives Core Web Vitals beacons (PERF-03). When set,
# LCP/CLS/INP/FCP/TTFB metrics are POSTed via navigator.sendBeacon. Unset in dev.
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=""
NEXT_TELEMETRY_DISABLED="1"
